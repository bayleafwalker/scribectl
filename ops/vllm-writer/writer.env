# vllm-writer environment (install to ~/.config/vllm/writer.env).
# The installed copy carries the real HF token; this repo copy is a template.
HUGGING_FACE_HUB_TOKEN=hf_REPLACE_ME

# The model is the whole point: set this to the bake-off winner.
# Candidates (all AWQ 4-bit, verified on HF 2026-07-12):
#   stelterlab/Mistral-Small-24B-Instruct-2501-AWQ   (Mistral Small 24B; the 3.2/2506
#     tekken-tokenizer AWQ trips a vllm 0.14.1 decode assertion — stay on 2501)
#   gaunernst/gemma-3-27b-it-int4-awq                (Gemma 3 27B; needs dtype auto/bf16)
#   tacodevs/Cydonia-24B-v4.3-AWQ                    (writing finetune of Mistral Small)
# Bake-off winner 2026-07-12 (operator verdict): Gemma — only draft where
# physical administrative detail carries the horror; faults local and coachable.
WRITER_MODEL=gaunernst/gemma-3-27b-it-int4-awq
# WRITER_DTYPE=auto  # default; Gemma 3 refuses float16

# Tuning knobs — RTX 3090 profile, single writing session, pack-sized prompts.
VLLM_PORT=8080
VLLM_MAX_LEN=16384
# 0.85 (not devstral's 0.90): the desktop session holds ~2 GB of VRAM.
GPU_MEM_UTIL=0.85
MAX_NUM_SEQS=1
MAX_BATCH_TOKENS=2048
