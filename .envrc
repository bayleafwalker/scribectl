# sprintctl runs in remote mode against the shared homelab postgres; the
# credentialed URL is injected from the gitignored .env.sprintctl.local
# (pattern matches homelab-analytics). Tenant isolation is by repo_id
# ("scribectl") recorded in .sprintctl/backend.json.
export SPRINTCTL_BACKEND=remote

_envrc_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
if [ -f "${_envrc_dir}/.env.sprintctl.local" ]; then
  # shellcheck disable=SC1091
  . "${_envrc_dir}/.env.sprintctl.local"
fi
unset _envrc_dir

export SPRINTCTL_URL="${SPRINTCTL_URL:?Set SPRINTCTL_URL from an injected secret or .env.sprintctl.local before entering this repo}"

# auditctl sidecar (same wiring as homelab-analytics)
export AUDITCTL_DB="${PWD}/.auditctl/auditctl.db"
export AUDITCTL_ARTIFACTS_ROOT="/projects/dev"
